# ==========================================================
# HomeWizard P1 Emulator - Configuration Template
# Rename this file to .env and fill in your details.
# ==========================================================

# 1. Home Assistant Connection
# Use the local IP of your Home Assistant instance
HA_URL="http://192.168.x.x:8123"

# Create a Long-Lived Access Token in HA: 
# Profile -> Security -> Long-Lived Access Tokens (at the bottom)
HA_TOKEN="YOUR_LONG_LIVED_ACCESS_TOKEN_HERE"

# 2. Emulator Settings
# Set to "true" to see live data updates in your terminal
DEBUG_MODE="true"

# Optional: Set a fixed 12-character hex string (e.g. AABBCCDDEEFF)
# If left empty, the script will auto-generate a unique ID.
# DEVICE_SERIAL=""

# 3. Sensor Entity IDs
# Find these in Home Assistant -> Settings -> Entities
SENSOR_IMPORT_T1="sensor.p1_energy_consumed_tariff_1"
SENSOR_IMPORT_T2="sensor.p1_energy_consumed_tariff_2"
SENSOR_EXPORT_T1="sensor.p1_energy_produced_tariff_1"
SENSOR_EXPORT_T2="sensor.p1_energy_produced_tariff_2"

# Main Power Sensors (Expected in kW or W, script converts to W)
SENSOR_POWER_CONSUMED="sensor.p1_power_consumed"
SENSOR_POWER_PRODUCED="sensor.p1_power_produced"

# --- OPTIONAL PHASE SENSORS (Leave empty if not used) ---
# SENSOR_POWER_L1=""
# SENSOR_VOLTAGE_L1=""
# SENSOR_CURRENT_L1=""

# --- OPTIONAL DIAGNOSTICS (Boolean sensors) ---
# SENSOR_SHORT_POWER_DROP=""
# SENSOR_POWER_FAIL=""